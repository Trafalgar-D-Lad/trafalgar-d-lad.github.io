---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Trafalgar D. Lad",
  url: "https://trafalgar-d-lad.github.io/",
  email: "mailto:trafalgar.d.lad@gmail.com",
  sameAs: ["https://www.linkedin.com/in/trafalgar-d-lad/", "https://github.com/Trafalgar-D-Lad"],
  jobTitle: "Créateur 3D, direction artistique et IA générative",
  knowsAbout: ["Blender", "Modélisation 3D", "Impression 3D", "IA générative", "Worldbuilding", "Prototypage"]
};
---
<BaseLayout
  title="Studio 3D & IA | Trafalgar D. Lad"
  description="Portfolio de Trafalgar D. Lad : direction artistique, modélisation 3D, IA générative, prototypage et impression 3D, du concept à la production."
  canonical="https://trafalgar-d-lad.github.io/"
  image="https://trafalgar-d-lad.github.io/images/sweetlandia/WB-400.webp"
  imageAlt="Carte officielle de l’univers Sweetlandia"
  current="home"
  jsonLd={jsonLd}
>
<main id="main-content">
<section class="hero">
<div class="container">
<img alt="Logo Trafalgar D. Lad — Studio 3D et IA" class="logo" fetchpriority="high" height="178" src="images/logo_26.webp" width="178"/>
<h1>Création 3D et IA pensée pour produire</h1>
<p class="hero-lead">Modélisation 3D, direction artistique assistée par IA et prototypage rapide.<br/>Du concept numérique à l’animation ou à l’objet prêt à produire.</p>
<div class="hero-cta">
<a class="btn-primary" href="projets.html" data-goatcounter-click="hero-projects">Découvrir mes projets</a>
<a class="btn-secondary btn-large" href="#contact" data-goatcounter-click="hero-contact">Discuter d’un projet</a>
</div>
<p class="hero-trust">Premier échange gratuit • Workflow structuré • Devis avant démarrage</p>
<p class="hero-collab">Basé à Bordeaux • Disponible pour missions freelance et collaborations à distance.</p>
</div>
</section>
<!-- VISION -->
<section class="vision section-alt">
<div class="container">
<h2 class="section-title">Vision</h2>
<p class="vision-text">Je conçois des univers visuels où l’intelligence artificielle, la modélisation 3D et la fabrication physique se rencontrent.<br/>Chaque projet est pensé comme un système cohérent, du concept numérique à l’animation ou à l’objet réel.</p>
</div>
</section>
<!-- FEATURED PROJECT -->
<section aria-labelledby="sweetlandia-title" class="featured-project" id="sweetlandia">
<div class="container">
<p class="section-kicker">Projet phare</p>
<h2 class="section-title">Sweetlandia</h2>
<div class="featured-project-card">
<div class="featured-project-visual">
<img alt="Carte officielle de l’univers Sweetlandia" decoding="async" height="1152" loading="lazy" src="images/sweetlandia/WB-400.webp" width="2048"/>
</div>
<div class="featured-project-content">
<p class="featured-eyebrow">Univers original • Préproduction active</p>
<h3 id="sweetlandia-title">Un monde gourmand conçu pour évoluer</h3>
<p class="featured-lead">Une propriété créative complète destinée à la BD ou au webtoon, aux environnements 3D, aux figurines, à l’artbook et aux produits dérivés.</p>
<ul aria-label="Compétences mobilisées" class="featured-skills">
<li>Direction artistique</li>
<li>Création d’univers</li>
<li>Concept art assisté par IA</li>
<li>Modélisation 3D</li>
<li>Bible de production</li>
</ul>
<a class="btn-primary" href="projets/sweetlandia.html" data-goatcounter-click="home-sweetlandia">Découvrir Sweetlandia</a>
</div>
</div>
</div>
</section>
<!-- PROJETS -->
<section class="projects-preview section-alt" id="projets">
<div class="container projects-preview-layout">
<div>
<p class="section-kicker">Portfolio</p>
<h2 class="section-title">Projets et réalisations</h2>
<p class="projects-preview-text">Motion design, création assistée par IA, modélisation 3D, architecture et prototypage : chaque réalisation présente un résultat, mais aussi une méthode et des contraintes de production.</p>
</div>
<div class="projects-preview-action">
<a class="btn-primary" href="projets.html">Voir tous les projets</a>
</div>
</div>
</section>
<!-- SERVICES -->
<section class="services" id="services">
<div class="container">
<h2 class="section-title">Services</h2>
<div class="services-grid">
<article class="service-card">
<h3 class="service-tag">Création 3D sur mesure</h3>
<p>Modélisation, mise en textures et assets optimisés pour l’animation, le rendu ou l’impression 3D. Livraison de fichiers adaptés à la production : STL, 3MF, OBJ, FBX et formats convenus.</p>
</article>
<article class="service-card">
<h3 class="service-tag">Prototypage &amp; impression 3D</h3>
<p>Préparation des fichiers, prototypes fonctionnels ou décoratifs, petites séries, lithophanies et créations HueForge, testés dans un véritable flux de fabrication.</p>
</article>
<article class="service-card">
<h3 class="service-tag">Direction artistique &amp; univers visuels</h3>
<p>Recherche visuelle, worldbuilding, concept art assisté par IA et développement d’identités cohérentes pour personnages, environnements et projets narratifs.</p>
</article>
</div>
</div>
</section>
<!-- METHODE -->
<section class="method section-alt">
<div class="container">
<h2 class="section-title">Méthode</h2>
<div class="method-steps">
<div><span class="step-number">01</span><strong>Analyse du besoin</strong></div>
<div><span class="step-number">02</span><strong>Concept et validation</strong></div>
<div><span class="step-number">03</span><strong>Création 3D et IA</strong></div>
<div><span class="step-number">04</span><strong>Optimisation production</strong></div>
<div><span class="step-number">05</span><strong>Livraison organisée</strong></div>
</div>
</div>
</section>
<!-- CREDIBILITY -->
<section class="credibility">
<div class="container">
<h2 class="section-title">Pourquoi me choisir ?</h2>
<div class="credibility-grid">
<div class="credibility-item">Pipeline local IA + Blender maîtrisé de bout en bout</div>
<div class="credibility-item">Assets pensés pour le rendu, l’animation ou la fabrication</div>
<div class="credibility-item">Expérience réelle de l’impression sur imprimante FDM</div>
<div class="credibility-item">Livrables structurés, documentés et réutilisables</div>
</div>
</div>
</section>
<!-- CONTACT -->
<section class="contact section-alt" id="contact">
<div class="container">
<h2 class="section-title">Un projet en tête ?</h2>
<p>Présentez-moi votre besoin. Je vous réponds avec une première orientation et une proposition adaptée.</p>
<div class="contact-direct">
<p>
          Vous pouvez aussi me contacter directement :
        </p>
<div class="contact-links">
<a href="mailto:trafalgar.d.lad@gmail.com" data-goatcounter-click="contact-email">
            Email
          </a>
<a href="https://www.linkedin.com/in/trafalgar-d-lad/" rel="noopener noreferrer" target="_blank" data-goatcounter-click="contact-linkedin">
            LinkedIn
          </a>
<a href="https://github.com/Trafalgar-D-Lad" rel="noopener noreferrer" target="_blank" data-goatcounter-click="contact-github">
            GitHub
          </a>
</div>
</div>
<form action="https://formspree.io/f/xpqjkovd" class="contact-form" method="POST">
<div class="form-field">
<label for="contact-name">Nom ou société</label>
<input autocomplete="name" id="contact-name" name="name" required="" type="text"/>
</div>
<div class="form-field">
<label for="contact-email">Adresse email</label>
<input autocomplete="email" id="contact-email" name="email" required="" type="email"/>
</div>
<div class="form-field">
<label for="contact-type">Type de projet</label>
<select id="contact-type" name="type" required="">
<option value="">Sélectionner</option>
<option>Modélisation 3D</option>
<option>Direction artistique IA</option>
<option>Prototypage / Impression 3D</option>
<option>Motion design / Logo 3D</option>
<option>Collaboration</option>
<option>Autre</option>
</select>
</div>
<div class="form-field">
<label for="contact-budget">Budget estimé <span>— optionnel</span></label>
<select id="contact-budget" name="budget">
<option value="">Sélectionner</option>
<option>Moins de 300€</option>
<option>300€ – 800€</option>
<option>800€ – 2000€</option>
<option>2000€ et plus</option>
<option>À discuter</option>
</select>
</div>
<div class="form-field">
<label for="contact-deadline">Échéance souhaitée <span>— optionnel</span></label>
<input id="contact-deadline" name="deadline" placeholder="Ex. septembre 2026" type="text"/>
</div>
<div class="form-field">
<label for="contact-message">Description du projet</label>
<textarea id="contact-message" name="message" required="" rows="6"></textarea>
</div>
<input autocomplete="off" class="honeypot" name="_gotcha" tabindex="-1" type="text"/>
<p class="form-note">Toutes les demandes sont étudiées sérieusement. Échange sans engagement.</p>
<button class="btn-primary" type="submit" data-goatcounter-click="contact-submit">Envoyer la demande</button>
</form>
<div aria-label="Liens professionnels" class="contact-links">
<a href="projets.html">Voir les réalisations</a>
</div>
</div>
</section>
<FeedbackForm />
</main>
</BaseLayout>
