<form class="contact-form" action="https://formspree.io/f/xpqjkovd" method="POST">
  <div class="form-field"><label for="contact-name">Nom ou société</label><input id="contact-name" type="text" name="name" autocomplete="name" required /></div>
  <div class="form-field"><label for="contact-email">Adresse email</label><input id="contact-email" type="email" name="email" autocomplete="email" required /></div>
  <div class="form-field"><label for="contact-type">Type de projet</label><select id="contact-type" name="type" required><option value="">Sélectionner</option><option>Modélisation 3D</option><option>Direction artistique IA</option><option>Prototypage / Impression 3D</option><option>Motion design / Logo 3D</option><option>Collaboration</option><option>Autre</option></select></div>
  <div class="form-field"><label for="contact-budget">Budget estimé <span>— optionnel</span></label><select id="contact-budget" name="budget"><option value="">Sélectionner</option><option>Moins de 300€</option><option>300€ – 800€</option><option>800€ – 2000€</option><option>2000€ et plus</option><option>À discuter</option></select></div>
  <div class="form-field"><label for="contact-deadline">Échéance souhaitée <span>— optionnel</span></label><input id="contact-deadline" type="text" name="deadline" placeholder="Ex. septembre 2026" /></div>
  <div class="form-field"><label for="contact-message">Description du projet</label><textarea id="contact-message" name="message" rows="6" required></textarea></div>
  <input class="honeypot" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
  <p class="form-note">Toutes les demandes sont étudiées sérieusement. Échange sans engagement.</p>
  <button class="btn-primary" type="submit">Envoyer la demande</button>
</form>
