---
interface Props {
  current?: 'home' | 'projects' | 'sweetlandia';
  base?: string;
}
const { current = 'home', base = '' } = Astro.props;
const home = `${base}/`;
const projects = `${base}/projets.html`;
const sweetlandia = `${base}/projets/sweetlandia.html`;
const contact = `${home}#contact`;
---
<header class="site-header">
  <div class="container header-inner">
    <a class="artist-name" href={home} aria-label="Retour à l’accueil">Trafalgar D. Lad</a>
    <nav class="nav" aria-label="Navigation principale">
      {current !== 'home' && <a class="nav-link" href={home}>Accueil</a>}
      <a class="nav-link" href={sweetlandia} aria-current={current === 'sweetlandia' ? 'page' : undefined}>Sweetlandia</a>
      <a class="nav-link" href={projects} aria-current={current === 'projects' ? 'page' : undefined}>Projets</a>
      {current === 'home' && <a class="nav-link" href="#services">Services</a>}
      <a class="btn-primary header-cta" href={contact}>Contact</a>
    </nav>
  </div>
</header>
